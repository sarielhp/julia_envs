#!/usr/bin/env ruby
# julia_envs - A colorful command-line utility to manage Julia named environments.
#
# Enables listing, describing, showing, adding packages, automatically 
# creating named environments based on imported packages in a Julia script, 
# matching scripts to environments, running scripts or REPLs, removing environments,
# and searching the general Julia package registry.

require 'fileutils'

ENV_DIR = File.join(Dir.home, '.julia', 'environments')

# Core terminal colors using standard ANSI escape codes
class String
  def bold;      "\e[1m#{self}\e[22m" end
  def red;       "\e[31m#{self}\e[0m"  end
  def green;     "\e[32m#{self}\e[0m"  end
  def yellow;    "\e[33m#{self}\e[0m"  end
  def blue;      "\e[34m#{self}\e[0m"  end
  def cyan;      "\e[36m#{self}\e[0m"  end
  def gray;      "\e[90m#{self}\e[0m"  end
end

# Custom lightweight parser for Julia Project.toml files
def parse_project_toml(file_path)
  data = { 'description' => nil, 'deps' => {} }
  return data unless File.exist?(file_path)

  current_section = nil
  File.foreach(file_path) do |line|
    clean_line = line.split('#').first.to_s.strip
    next if clean_line.empty?

    if clean_line =~ /^\[(.*)\]$/
      current_section = $1.strip
      next
    end

    if clean_line =~ /^([^=]+)=(.*)$/
      key = $1.strip
      val = $2.strip.gsub(/^"(.*)"$/, '\1')

      if current_section.nil? && key == 'description'
        data['description'] = val
      elsif current_section == 'deps'
        data['deps'][key] = val
      end
    end
  end
  data
end

# Extract Julia packages used in a script
def extract_packages(script_path)
  packages = []
  unless File.exist?(script_path)
    puts "Error: Script file not found: #{script_path}".red
    return packages
  end

  File.foreach(script_path) do |line|
    clean_line = line.split('#').first.to_s.strip
    next if clean_line.empty?

    if clean_line =~ /^\s*(using|import)\s+(.*)$/
      raw_pkg_list = $2
      parts = raw_pkg_list.split(/[,:]/)
      parts.each do |part|
        pkg = part.strip
        # Julia package names start with an uppercase letter
        if !pkg.empty? && pkg =~ /^[A-Z]/
          pkg_name = pkg.split(/\s+/).first
          packages << pkg_name unless packages.include?(pkg_name)
        end
      end
    end
  end
  packages
end

# Update or insert the description key in a Project.toml file
def update_description(file_path, new_desc)
  FileUtils.mkdir_p(File.dirname(file_path))
  lines = File.exist?(file_path) ? File.readlines(file_path) : []
  description_replaced = false

  updated_lines = lines.map do |line|
    if line =~ /^\s*description\s*=\s*".*"\s*$/
      description_replaced = true
      "description = \"#{new_desc}\"\n"
    else
      line
    end
  end

  unless description_replaced
    updated_lines.unshift("description = \"#{new_desc}\"\n\n")
  end

  File.write(file_path, updated_lines.join)
end

def list_environments
  unless Dir.exist?(ENV_DIR)
    puts "No Julia environments directory found at #{ENV_DIR}.".red
    return
  end

  envs = Dir.children(ENV_DIR).select { |entry| File.directory?(File.join(ENV_DIR, entry)) }.sort

  puts "\n#{"Environment".bold.cyan}  #{"Description".bold.cyan}"
  puts "-" * 80

  envs.each do |env|
    toml_path = File.join(ENV_DIR, env, 'Project.toml')
    data = parse_project_toml(toml_path)
    desc = data['description'] || "(No description)".gray
    
    env_display = env == 'v1.12' ? "v1.12 (Global)".yellow : "@#{env}".green
    puts "%-24s %-50s" % [env_display, desc]
  end
  puts ""
end

def show_environment(env_name)
  clean_name = env_name.start_with?('@') ? env_name[1..] : env_name
  env_path = File.join(ENV_DIR, clean_name)
  toml_path = File.join(env_path, 'Project.toml')

  unless File.exist?(toml_path)
    puts "Error: Named environment '@#{clean_name}' does not exist.".red
    return
  end

  data = parse_project_toml(toml_path)
  puts "\n#{"Environment:".bold.cyan} #{"@#{clean_name}".green}"
  puts "#{"Description:".bold.cyan} #{data['description'] || '(No description)'.gray}"
  puts "-" * 40
  
  if data['deps'].empty?
    puts "No registered packages found.".yellow
  else
    puts "Registered Packages (Direct Dependencies):".bold
    data['deps'].keys.sort.each do |pkg|
      puts "  - #{pkg.green}"
    end
  end
  puts ""
end

def add_packages(env_name, packages)
  if packages.empty?
    puts "Error: Please specify at least one package to add.".red
    return
  end

  clean_name = env_name.start_with?('@') ? env_name[1..] : env_name
  puts "Adding package(s) #{packages.join(', ').green} to '@#{clean_name}'..."
  
  pkg_array = packages.map { |p| "\"#{p}\"" }.join(', ')
  cmd = "julia --project=@#{clean_name} -e 'using Pkg; Pkg.add([#{pkg_array}])'"
  
  if system(cmd)
    puts "\nSuccessfully added package(s) to '@#{clean_name}'!".green.bold
  else
    puts "\nError: Failed to add package(s) to '@#{clean_name}'.".red.bold
  end
end

def describe_environment(env_name, description)
  clean_name = env_name.start_with?('@') ? env_name[1..] : env_name
  env_path = File.join(ENV_DIR, clean_name)
  toml_path = File.join(env_path, 'Project.toml')

  update_description(toml_path, description)
  puts "Successfully updated description for '@#{clean_name}'.".green
end

def create_from_script(env_name, script_path)
  clean_name = env_name.start_with?('@') ? env_name[1..] : env_name
  
  unless File.exist?(script_path)
    puts "Error: Script file not found: #{script_path}".red
    return
  end

  puts "Scanning script #{script_path.yellow} for imports..."
  packages = extract_packages(script_path)

  if packages.empty?
    puts "No external packages detected in script. Environment was not created.".yellow
    return
  end

  puts "Detected packages: #{packages.join(', ').green}"
  
  env_path = File.join(ENV_DIR, clean_name)
  toml_path = File.join(env_path, 'Project.toml')
  desc = "Auto-generated environment for running #{File.basename(script_path)}"
  update_description(toml_path, desc)

  add_packages(clean_name, packages)
end

def find_matching_environments(script_path)
  unless File.exist?(script_path)
    puts "Error: Script file not found: #{script_path}".red
    return
  end

  puts "Scanning script #{script_path.yellow} for imports..."
  required_packages = extract_packages(script_path)

  if required_packages.empty?
    puts "No external packages detected in: #{script_path}".yellow
    return
  end

  puts "Required packages: #{required_packages.join(', ').green}"
  
  unless Dir.exist?(ENV_DIR)
    puts "No Julia environments directory found at #{ENV_DIR}.".red
    return
  end

  envs = Dir.children(ENV_DIR).select { |entry| File.directory?(File.join(ENV_DIR, entry)) }.sort
  matching_envs = []

  envs.each do |env|
    toml_path = File.join(ENV_DIR, env, 'Project.toml')
    next unless File.exist?(toml_path)

    data = parse_project_toml(toml_path)
    deps = data['deps'].keys
    
    if required_packages.all? { |pkg| deps.include?(pkg) }
      matching_envs << env
    end
  end

  puts "\n#{"Matching Environments:".bold.cyan}"
  if matching_envs.empty?
    puts "  No existing environments satisfy all required dependencies.".yellow
    puts "  Tip: You can create a new environment for this script by running:".gray
    puts "       julia_envs create @new_env_name #{script_path}".gray
  else
    matching_envs.each do |env|
      env_display = env == 'v1.12' ? "v1.12 (Global)".yellow : "@#{env}".green
      puts "  - #{env_display}"
    end
  end
  puts ""
end

def run_script(env_name, script_path, args)
  clean_name = env_name.start_with?('@') ? env_name[1..] : env_name
  unless File.exist?(script_path)
    puts "Error: Script file not found: #{script_path}".red
    return
  end

  # Replace the current Ruby process with standard julia running the script
  # under the specified named project environment
  exec "julia", "--project=@#{clean_name}", script_path, *args
end

def launch_repl(env_name)
  clean_name = env_name.start_with?('@') ? env_name[1..] : env_name
  puts "Launching Julia REPL in named environment '#{"@#{clean_name}".green}'...".bold
  
  # Replace the current Ruby process with standard julia REPL
  exec "julia", "--project=@#{clean_name}"
end

def remove_environment(env_name)
  clean_name = env_name.start_with?('@') ? env_name[1..] : env_name
  env_path = File.join(ENV_DIR, clean_name)
  
  unless Dir.exist?(env_path)
    puts "Error: Named environment '@#{clean_name}' does not exist.".red
    return
  end

  print "Are you sure you want to delete named environment #{"@#{clean_name}".green}? [y/N]: ".bold.red
  response = $stdin.gets.strip.downcase
  
  if ['y', 'yes'].include?(response)
    FileUtils.rm_rf(env_path)
    puts "Successfully deleted environment '@#{clean_name}'.".green.bold
  else
    puts "Deletion cancelled.".yellow
  end
end

def search_packages(query)
  if query.nil? || query.empty?
    puts "Error: Please specify a search query.".red
    return
  end

  puts "Searching Julia registry for '#{query.yellow}'..."
  
  # Invoke Julia one-liner to search reachable registries
  julia_code = <<~JULIA
    let
        using Pkg
        query = lowercase(ARGS[1])
        counter = 0
        for reg in Pkg.Registry.reachable_registries()
            sorted_pkgs = sort(collect(values(reg.pkgs)), by=x->x.name)
            for pkg in sorted_pkgs
                if occursin(query, lowercase(pkg.name))
                    println(pkg.name)
                    counter += 1
                    if counter >= 25
                        println("__TRUNCATED__")
                        return
                    end
                end
            end
        end
    end
  JULIA

  output = `julia -e '#{julia_code.gsub("\n", "; ")}' -- "#{query}"`
  lines = output.split("\n").map(&:strip).reject(&:empty?)
  
  if lines.empty?
    puts "No matching packages found for '#{query}'.".yellow
  else
    puts "\n#{"Matching Packages (from General Registry):".bold.cyan}"
    truncated = false
    lines.each do |line|
      if line == "__TRUNCATED__"
        truncated = true
      else
        puts "  - #{line.green}"
      end
    end
    if truncated
      puts "  - ... and more results (truncated to 25)".gray
    end
    puts ""
  end
end

def print_help
  puts <<~HELP
    #{"julia_envs".bold.cyan} - Manage Julia Named Environments

    #{"Usage:".bold.yellow}
      julia_envs list                            List all environments and descriptions
      julia_envs show <env_name>                 Show registered packages in an environment
      julia_envs add <env_name> <pkg1> <pkg2>..  Add packages to a named environment
      julia_envs describe <env_name> "<desc>"    Add/change description of an environment
      julia_envs create <env_name> <script.jl>   Create an environment from a Julia script
      julia_envs match <script.jl>               Find environments that can run a script
      julia_envs run <env_name> <script.jl> [..] Run a Julia script in a named environment
      julia_envs repl <env_name>                 Launch Julia REPL in a named environment
      julia_envs rm <env_name>                   Delete a named environment
      julia_envs search <query>                  Search General Registry for a package

    #{"Examples:".bold.yellow}
      julia_envs list
      julia_envs show @plotting
      julia_envs add @plotting DataStructures DataFrames
      julia_envs describe @plotting "Plotting environment with Plots.jl and Cairo"
      julia_envs create @math_env solve_inequality.jl
      julia_envs match plot_inequality.jl
      julia_envs run @plotting plot_inequality.jl
      julia_envs repl @plotting
      julia_envs rm @test_env
      julia_envs search DataStructures
  HELP
end

# Main entry point parsing arguments
action = ARGV.shift

case action
when 'list'
  list_environments
when 'show'
  env_name = ARGV.shift
  if env_name.nil?
    puts "Error: Please specify an environment name.".red
  else
    show_environment(env_name)
  end
when 'add'
  env_name = ARGV.shift
  if env_name.nil?
    puts "Error: Please specify an environment name.".red
  else
    add_packages(env_name, ARGV)
  end
when 'describe'
  env_name = ARGV.shift
  description = ARGV.shift
  if env_name.nil? || description.nil?
    puts "Error: Usage: julia_envs describe <env_name> \"<description>\"".red
  else
    describe_environment(env_name, description)
  end
when 'create'
  env_name = ARGV.shift
  script_path = ARGV.shift
  if env_name.nil? || script_path.nil?
    puts "Error: Usage: julia_envs create <env_name> <script.jl>".red
  else
    create_from_script(env_name, script_path)
  end
when 'match'
  script_path = ARGV.shift
  if script_path.nil?
    puts "Error: Usage: julia_envs match <script.jl>".red
  else
    find_matching_environments(script_path)
  end
when 'run'
  env_name = ARGV.shift
  script_path = ARGV.shift
  if env_name.nil? || script_path.nil?
    puts "Error: Usage: julia_envs run <env_name> <script.jl> [args...]".red
  else
    run_script(env_name, script_path, ARGV)
  end
when 'repl'
  env_name = ARGV.shift
  if env_name.nil?
    puts "Error: Usage: julia_envs repl <env_name>".red
  else
    launch_repl(env_name)
  end
when 'rm', 'delete'
  env_name = ARGV.shift
  if env_name.nil?
    puts "Error: Usage: julia_envs rm <env_name>".red
  else
    remove_environment(env_name)
  end
when 'search'
  query = ARGV.shift
  if query.nil?
    puts "Error: Usage: julia_envs search <query>".red
  else
    search_packages(query)
  end
else
  print_help
end
